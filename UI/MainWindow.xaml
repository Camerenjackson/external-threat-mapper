<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="External Threat Mapper" Height="820" Width="1360" MinHeight="680" MinWidth="1100"
        Background="#080B10" Foreground="#EEF2F8" FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <SolidColorBrush x:Key="SidebarBg" Color="#0C1018"/>
    <SolidColorBrush x:Key="PanelBg" Color="#121820"/>
    <SolidColorBrush x:Key="PanelHover" Color="#1A2433"/>
    <SolidColorBrush x:Key="Line" Color="#263041"/>
    <SolidColorBrush x:Key="Accent" Color="#4C9AFF"/>
    <SolidColorBrush x:Key="AccentDim" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="Good" Color="#3DD68C"/>
    <SolidColorBrush x:Key="Warn" Color="#F0B429"/>
    <SolidColorBrush x:Key="Bad" Color="#F85149"/>
    <LinearGradientBrush x:Key="LogoGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#2B6CB0" Offset="0"/>
      <GradientStop Color="#4C9AFF" Offset="1"/>
    </LinearGradientBrush>
    <Style x:Key="NavItem" TargetType="ListBoxItem">
      <Setter Property="Foreground" Value="#8B9BB4"/>
      <Setter Property="Padding" Value="14,11"/>
      <Setter Property="Margin" Value="8,2"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDim}"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelHover}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource Accent}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="18,9"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
      <Setter Property="Background" Value="#1A2433"/>
      <Setter Property="Foreground" Value="#C5D0E0"/>
    </Style>
    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
      <Setter Property="Background" Value="#5C1F1F"/>
      <Setter Property="Foreground" Value="#FFB4B0"/>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style x:Key="Lbl" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#7D8DA6"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#0A0E14"/>
      <Setter Property="Foreground" Value="#EEF2F8"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
    <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
      <Setter Property="Background" Value="#121820"/>
      <Setter Property="Foreground" Value="#EEF2F8"/>
      <Setter Property="Padding" Value="10,8"/>
      <Style.Triggers>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="#243044"/>
          <Setter Property="Foreground" Value="#FFFFFF"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#1E3A5F"/>
          <Setter Property="Foreground" Value="#FFFFFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="DarkCombo" TargetType="ComboBox">
      <Setter Property="Foreground" Value="#EEF2F8"/>
      <Setter Property="Background" Value="#121820"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="Margin" Value="0,0,0,10"/>
      <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton x:Name="Toggle" Grid.Column="1" Focusable="False" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                            Background="#121820" BorderBrush="{StaticResource Line}" BorderThickness="1" Foreground="#EEF2F8">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                  </Grid.ColumnDefinitions>
                  <ContentPresenter Margin="10,6" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                  <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,5 L8,0 Z" Fill="#8B9BB4"/>
                </Grid>
              </ToggleButton>
              <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                <Border Background="#121820" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="280">
                  <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#1A2433"/>
      <Setter Property="Foreground" Value="#C5D0E0"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="#0A0E14"/>
      <Setter Property="Foreground" Value="#EEF2F8"/>
      <Setter Property="RowBackground" Value="#10161F"/>
      <Setter Property="AlternatingRowBackground" Value="#0C121A"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="GridLinesVisibility" Value="None"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="AutoGenerateColumns" Value="True"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="RowHeight" Value="36"/>
      <Setter Property="CanUserResizeRows" Value="False"/>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="0,1"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#1A2838"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#1E3A5F"/>
          <Setter Property="Foreground" Value="#FFFFFF"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="EtmScrollBarThumb" TargetType="Thumb">
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Setter Property="IsTabStop" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="ThumbBd" CornerRadius="6" Margin="2,3" Opacity="0.85">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#2B6CB0" Offset="0"/>
                  <GradientStop Color="#5CB0FF" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbBd" Property="Opacity" Value="1"/>
                <Setter TargetName="ThumbBd" Property="Effect">
                  <Setter.Value>
                    <DropShadowEffect Color="#4C9AFF" BlurRadius="12" ShadowDepth="0" Opacity="0.75"/>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbBd" Property="Background">
                  <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#4C9AFF" Offset="0"/>
                      <GradientStop Color="#7EC8FF" Offset="1"/>
                    </LinearGradientBrush>
                  </Setter.Value>
                </Setter>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="EtmScrollBar" TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid x:Name="Bg" Background="#0E141C" Margin="2">
              <Border Background="#151C28" CornerRadius="7" BorderBrush="#263041" BorderThickness="1"/>
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.Thumb>
                  <Thumb Style="{StaticResource EtmScrollBarThumb}"/>
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Height" Value="14"/>
          <Setter Property="Width" Value="Auto"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid Background="#0E141C" Margin="2">
                  <Border Background="#151C28" CornerRadius="7" BorderBrush="#263041" BorderThickness="1"/>
                  <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.Thumb>
                      <Thumb Style="{StaticResource EtmScrollBarThumb}"/>
                    </Track.Thumb>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
        <Trigger Property="Orientation" Value="Vertical">
          <Setter Property="Width" Value="14"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="ScrollBar" BasedOn="{StaticResource EtmScrollBar}"/>
    <Style x:Key="DashTabItem" TargetType="TabItem">
      <Setter Property="Foreground" Value="#8B9BB4"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="8,8,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
              <ContentPresenter ContentSource="Header"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#1A2433"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#141C28"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="DashTabControl" TargetType="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="#EEF2F8"/>
    </Style>
    <Style TargetType="ProgressBar">
      <Setter Property="Background" Value="#1A2433"/>
      <Setter Property="Foreground" Value="{StaticResource Accent}"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style TargetType="ListBox">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="232"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Border Grid.Column="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
      <DockPanel Margin="0,12">
        <StackPanel DockPanel.Dock="Top" Margin="16,8,16,20">
          <Image x:Name="ImgSidebarLogo" Width="44" Height="44" Margin="0,0,0,12"/>
          <TextBlock Text="THREAT MAPPER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
          <TextBlock Text="External surface" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,0"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
          <ProgressBar x:Name="ScanProgress" Height="3" Maximum="100" Visibility="Collapsed" Foreground="{StaticResource Accent}" Background="#1A2433" BorderThickness="0"/>
          <TextBlock x:Name="TxtProgressMsg" FontSize="10" Foreground="#6B7A92" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>
        <ListBox x:Name="NavList" ItemContainerStyle="{StaticResource NavItem}">
          <ListBoxItem Content="Dashboard" Tag="Dashboard" IsSelected="True"/>
          <ListBoxItem Content="Target" Tag="Target"/>
          <ListBoxItem Content="Discovery" Tag="Discovery"/>
          <ListBoxItem Content="Threat Intel" Tag="Intel"/>
          <ListBoxItem Content="Integrations" Tag="Integrations"/>
          <ListBoxItem Content="SQL Database" Tag="Sql"/>
          <ListBoxItem Content="History" Tag="History"/>
          <ListBoxItem Content="Reports" Tag="Reports"/>
        </ListBox>
      </DockPanel>
    </Border>
    <Grid Grid.Column="1" Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid Grid.Row="0" Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock x:Name="TxtPageTitle" Text="Dashboard" FontSize="26" FontWeight="SemiBold"/>
          <TextBlock x:Name="TxtStatus" Foreground="#7D8DA6" Margin="0,4,0,0" Text="Authorize your target, connect APIs, then run a scan."/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="BtnLoadDemo" Content="Demo" Style="{StaticResource BtnGhost}" Margin="0,0,8,0"/>
          <Button x:Name="BtnClearDemo" Content="Clear" Style="{StaticResource BtnGhost}" Margin="0,0,8,0"/>
          <Button x:Name="BtnStartScan" Content="Run scan" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0"/>
          <Button x:Name="BtnCancelScan" Content="Stop" Style="{StaticResource BtnDanger}" Visibility="Collapsed"/>
        </StackPanel>
      </Grid>
      <Grid Grid.Row="1" x:Name="PageHost">
        <Grid x:Name="PageDashboard">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="SCORE" Style="{StaticResource Lbl}"/>
                <TextBlock x:Name="TxtScore" Text="--" FontSize="38" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                <TextBlock x:Name="TxtGrade" TextWrapping="Wrap" Foreground="#8B9BB4" FontSize="11"/>
              </StackPanel>
            </Border>
            <Border x:Name="CardFindings" Style="{StaticResource Card}" Margin="4,0" Cursor="Hand" ToolTip="Open findings list">
              <StackPanel>
                <TextBlock Text="FINDINGS" Style="{StaticResource Lbl}"/>
                <TextBlock x:Name="TxtFindingCount" Text="0" FontSize="38" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border x:Name="CardAssets" Style="{StaticResource Card}" Margin="4,0" Cursor="Hand" ToolTip="Open assets list">
              <StackPanel>
                <TextBlock Text="ASSETS" Style="{StaticResource Lbl}"/>
                <TextBlock x:Name="TxtAssetCount" Text="0" FontSize="38" FontWeight="Bold" Foreground="{StaticResource Good}"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
              <StackPanel>
                <TextBlock Text="INTEL FEEDS" Style="{StaticResource Lbl}"/>
                <TextBlock x:Name="TxtIntelCount" Text="0" FontSize="38" FontWeight="Bold" Foreground="{StaticResource Warn}"/>
              </StackPanel>
            </Border>
          </UniformGrid>
          <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
              <StackPanel DockPanel.Dock="Top" Margin="16,14,16,4">
                <TextBlock Text="Scan results" FontWeight="SemiBold"/>
                <TextBlock Text="Double-click any row for risk details, discovery method, and remediation." Foreground="#6B7A92" FontSize="11" Margin="0,4,0,0"/>
              </StackPanel>
              <TabControl x:Name="DashResultTabs" DockPanel.Dock="Top" Style="{StaticResource DashTabControl}" Margin="12,0,12,0">
                <TabItem Header="Findings" Style="{StaticResource DashTabItem}">
                  <DataGrid x:Name="GridFindings" Margin="0,8,0,8" MinHeight="220"/>
                </TabItem>
                <TabItem Header="Assets" Style="{StaticResource DashTabItem}">
                  <DataGrid x:Name="GridAssets" Margin="0,8,0,8" MinHeight="220"/>
                </TabItem>
              </TabControl>
            </DockPanel>
          </Border>
        </Grid>
        <Grid x:Name="PageTarget" Visibility="Collapsed">
          <Border Style="{StaticResource Card}" HorizontalAlignment="Left" MaxWidth="520">
            <StackPanel>
              <TextBlock Text="Assessment target" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
              <TextBlock Text="ORGANIZATION" Style="{StaticResource Lbl}"/>
              <TextBox x:Name="TxtOrg"/>
              <TextBlock Text="PRIMARY DOMAIN" Style="{StaticResource Lbl}"/>
              <TextBox x:Name="TxtDomain"/>
              <TextBlock Text="SCAN MODE" Style="{StaticResource Lbl}"/>
              <ComboBox x:Name="CmbScanMode" Style="{StaticResource DarkCombo}">
                <ComboBoxItem Content="PassiveOnly" IsSelected="True"/>
                <ComboBoxItem Content="CorporateSafe"/>
                <ComboBoxItem Content="FullAuthorized"/>
              </ComboBox>
              <CheckBox x:Name="ChkAuthorized" Foreground="#EEF2F8" Margin="0,4,0,8"
                        Content="I have written authorization to assess this target."/>
              <TextBlock Text="HIBP SEED EMAILS (OPTIONAL)" Style="{StaticResource Lbl}"/>
              <TextBox x:Name="TxtBreachEmails" ToolTip="Comma-separated authorized mailboxes for single-account HIBP checks. Domain-wide breach search uses primary domain automatically."/>
              <TextBlock TextWrapping="Wrap" Foreground="#6B7A92" FontSize="10" Margin="0,0,0,12"
                         Text="Corporate scans use HIBP domain search (all @yourdomain aliases). Add up to 5 specific emails only if you are authorized to check them. Verify the domain in your HIBP dashboard first."/>
              <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSaveScope" Content="Save scope" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0"/>
                <Button x:Name="BtnLoadScope" Content="Load scope" Style="{StaticResource BtnGhost}"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
        <Grid x:Name="PageDiscovery" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="FILTER" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="CmbDiscoveryFilter" Width="200" Margin="0" Style="{StaticResource DarkCombo}">
              <ComboBoxItem Content="All assets" IsSelected="True"/>
              <ComboBoxItem Content="Subdomains"/>
              <ComboBoxItem Content="Web services"/>
              <ComboBoxItem Content="Typosquatting"/>
              <ComboBoxItem Content="Cloud"/>
              <ComboBoxItem Content="GitHub"/>
              <ComboBoxItem Content="Breaches"/>
            </ComboBox>
          </StackPanel>
          <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Margin="16,14,16,8" FontWeight="SemiBold"
                         Text="Discovered assets — double-click a row for full detail"/>
              <DataGrid x:Name="GridDiscovery" Margin="8,0,8,8"/>
            </DockPanel>
          </Border>
        </Grid>
        <Grid x:Name="PageIntel" Visibility="Collapsed">
          <Border Style="{StaticResource Card}" Padding="0">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Margin="16,14,16,8" FontWeight="SemiBold"
                         Text="API enrichment — double-click a row for provider and source detail"/>
              <DataGrid x:Name="GridIntel" Margin="8,0,8,8"/>
            </DockPanel>
          </Border>
        </Grid>
        <Grid x:Name="PageIntegrations" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="BtnTestAllApis" Content="Test all connections" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0"/>
            <TextBlock x:Name="TxtApiSummary" VerticalAlignment="Center" Foreground="#7D8DA6"/>
          </StackPanel>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="IntegrationsPanel"/>
          </ScrollViewer>
        </Grid>
        <Grid x:Name="PageSql" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel MaxWidth="720">
              <TextBlock Text="SQL Server connection" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
              <TextBlock TextWrapping="Wrap" Foreground="#7D8DA6" FontSize="11" Margin="0,0,0,12"
                         Text="Enter your server details and click Connect. Database tools unlock after a successful connection."/>
              <TextBlock Text="SERVER" Style="{StaticResource Lbl}"/>
              <TextBox x:Name="TxtSqlServer"/>
              <TextBlock Text="DATABASE" Style="{StaticResource Lbl}"/>
              <TextBox x:Name="TxtSqlDatabase"/>
              <CheckBox x:Name="ChkSqlIntegrated" Content="Windows authentication" Foreground="#EEF2F8" Margin="0,0,0,8"/>
              <TextBlock Text="SQL USER (if not Windows auth)" Style="{StaticResource Lbl}"/>
              <TextBox x:Name="TxtSqlUser"/>
              <TextBlock Text="SQL PASSWORD" Style="{StaticResource Lbl}"/>
              <PasswordBox x:Name="PwdSql" Height="32" Margin="0,0,0,10"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnSqlConnect" Content="Connect" Style="{StaticResource BtnPrimary}" Margin="0,0,8,0" Padding="16,8"/>
                <Button x:Name="BtnSqlDisconnect" Content="Disconnect" Style="{StaticResource BtnGhost}" Padding="16,8" Visibility="Collapsed"/>
              </StackPanel>
              <TextBlock x:Name="TxtSqlConnectStatus" TextWrapping="Wrap" Foreground="#7D8DA6" FontSize="11"/>
            </StackPanel>
          </Border>
          <Grid Grid.Row="1">
            <Border x:Name="SqlLockedOverlay" Style="{StaticResource Card}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                <TextBlock Text="Database tools locked" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock TextWrapping="Wrap" Foreground="#7D8DA6" FontSize="12" Margin="0,10,0,0" MaxWidth="420" TextAlignment="Center"
                           Text="Connect to SQL Server above to view synced scans and enable automatic scan upload."/>
              </StackPanel>
            </Border>
            <Border x:Name="SqlWorkspace" Style="{StaticResource Card}" Padding="0" Visibility="Collapsed">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,14,16,8">
                  <TextBlock x:Name="TxtSqlConnectedBanner" Text="Connected" FontWeight="SemiBold" Foreground="{StaticResource Good}"/>
                  <CheckBox x:Name="ChkSqlEnabled" Content="Automatically sync completed scans to SQL" Foreground="#EEF2F8" Margin="0,10,0,0"/>
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="BtnSqlRefresh" Content="Refresh from database" Style="{StaticResource BtnGhost}" Padding="12,6" Margin="0,0,8,0"/>
                    <Button x:Name="BtnSqlSaveSync" Content="Save sync preference" Style="{StaticResource BtnPrimary}" Padding="12,6"/>
                  </StackPanel>
                  <TextBlock x:Name="TxtSqlWorkspaceStatus" TextWrapping="Wrap" Foreground="#7D8DA6" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
                <DataGrid x:Name="GridSqlScans" Margin="8,0,8,8"/>
              </DockPanel>
            </Border>
          </Grid>
        </Grid>
        <Grid x:Name="PageHistory" Visibility="Collapsed">
          <Border Style="{StaticResource Card}" Padding="0">
            <DockPanel>
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,14,16,8">
                <TextBlock Text="Local scan history" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="(saved under data/history/)" Foreground="#7D8DA6" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Button x:Name="BtnLoadHistory" Content="Load selected" Style="{StaticResource BtnPrimary}" Margin="12,0,8,0" Padding="12,6"/>
                <Button x:Name="BtnClearHistory" Content="Clear all" Style="{StaticResource BtnDanger}" Padding="12,6"/>
              </StackPanel>
              <DataGrid x:Name="GridHistory" Margin="8,0,8,8"/>
            </DockPanel>
          </Border>
        </Grid>
        <Grid x:Name="PageReports" Visibility="Collapsed">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Border Style="{StaticResource Card}" Margin="0,0,12,0">
            <StackPanel>
              <TextBlock Text="Export" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
              <Button x:Name="BtnExportHtml" Content="HTML report" Style="{StaticResource BtnPrimary}" Margin="0,0,0,8"/>
              <Button x:Name="BtnExportCsv" Content="CSV findings" Style="{StaticResource BtnGhost}" Margin="0,0,0,8"/>
              <Button x:Name="BtnExportJson" Content="JSON bundle" Style="{StaticResource BtnGhost}"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Text="Activity log" Margin="16,14,16,8" FontWeight="SemiBold"/>
              <TextBox x:Name="TxtLogs" Margin="12,0,12,12" IsReadOnly="True" TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                       Background="#0A0E14" BorderThickness="0"/>
            </DockPanel>
          </Border>
        </Grid>
        <Grid x:Name="DetailOverlay" Visibility="Collapsed" Panel.ZIndex="200" Background="#80080B10">
          <Border HorizontalAlignment="Right" Width="460" Background="#0F141C" BorderBrush="#263041" BorderThickness="1,0,0,0">
            <Border.Effect>
              <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="-4" Opacity="0.6"/>
            </Border.Effect>
            <DockPanel>
              <Grid DockPanel.Dock="Top" Margin="18,16,18,8">
                <StackPanel>
                  <TextBlock x:Name="DetailTitle" Text="Details" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,40,0"/>
                  <TextBlock x:Name="DetailSubtitle" Foreground="#7D8DA6" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
                <Button x:Name="BtnDetailClose" Content="✕" Style="{StaticResource BtnGhost}" Width="36" Height="36"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Padding="0" ToolTip="Close"/>
              </Grid>
              <Border DockPanel.Dock="Top" Height="1" Background="#263041" Margin="18,0"/>
              <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DetailFieldsPanel" Margin="18,8,18,20"/>
              </ScrollViewer>
            </DockPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
